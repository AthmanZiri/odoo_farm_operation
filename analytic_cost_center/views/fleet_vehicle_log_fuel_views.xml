<odoo>
    <record id="fleet_vehicle_log_fuel_view_form_analytic" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.fuel.form.analytic</field>
        <field name="model">fleet.vehicle.log.fuel</field>
        <field name="inherit_id" ref="fleet_vehicle_log_fuel.fleet_vehicle_log_fuel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vehicle_id']" position="before">
                <field name="analytic_plan_id" options="{'no_create': True}" invisible="1"/>
                <field name="analytic_account_id" options="{'no_create': True}"/>
                <field name="analytic_distribution" widget="analytic_distribution" groups="analytic.group_analytic_accounting" invisible="1"/>
            </xpath>
        </field>
    </record>
    <record id="fleet_vehicle_log_fuel_view_search_analytic" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.fuel.search.analytic</field>
        <field name="model">fleet.vehicle.log.fuel</field>
        <field name="inherit_id" ref="fleet_vehicle_log_fuel.fleet_vehicle_log_fuel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="analytic_account_id" string="Cost Center"/>
            </xpath>
            <xpath expr="//filter[@name='group_category']" position="after">
                <filter string="Cost Center" name="group_analytic_account"
                        context="{'group_by': 'analytic_account_id'}"/>
            </xpath>
        </field>
    </record>
    <record id="fleet_vehicle_log_fuel_view_tree_analytic" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.fuel.tree.analytic</field>
        <field name="model">fleet.vehicle.log.fuel</field>
        <field name="inherit_id" ref="fleet_vehicle_log_fuel.fleet_vehicle_log_fuel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vehicle_id']" position="after">
                <field name="analytic_account_id" optional="hide" string="Cost Center"/>
            </xpath>
        </field>
    </record>
    <record id="fleet_vehicle_log_fuel_view_pivot_analytic" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.fuel.pivot.analytic</field>
        <field name="model">fleet.vehicle.log.fuel</field>
        <field name="inherit_id" ref="fleet_vehicle_log_fuel.fleet_vehicle_log_fuel_view_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="analytic_account_id" type="row"/>
            </xpath>
        </field>
    </record>
</odoo>
